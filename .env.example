# Application
NODE_ENV=development
PORT=5000
WS_PORT=5001
APP_NAME=dsr-api
APP_PUBLIC_URL=http://localhost:3000
LOG_LEVEL=info

# Frontend URLs (used for CORS and invite links)
LANDING_PAGE_URL=http://localhost:5176
TENANT_PLATFORM_URL=http://localhost:5175
SUPER_ADMIN_URL=http://localhost:5174

# CORS: comma-separated origins. If unset, derived from LANDING_PAGE_URL,TENANT_PLATFORM_URL,SUPER_ADMIN_URL
# CORS_ORIGIN=http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/dsr_dev
# If you get querySrv ECONNREFUSED with Atlas SRV, set MONGODB_URI_STANDARD to the standard connection string from Atlas (Connect -> Drivers).
# MONGODB_URI_STANDARD=

# Redis
REDIS_URL=redis://127.0.0.1:6379
QUEUE_CONCURRENCY=5

# JWT
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_COOKIE_NAME=refreshToken
JWT_REFRESH_COOKIE_HTTP_ONLY=true
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_SAME_SITE=strict
JWT_REFRESH_COOKIE_MAX_AGE=604800000

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="DSR <your-email@example.com>"

# AI (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini-2024-07-18
# OPENAI_BASE_URL=  # optional for non-OpenAI providers

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
