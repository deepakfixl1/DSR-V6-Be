{
  "name": "repo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#api/*": "./apps/api/src/*",
    "#db/*": "./packages/db/src/*",
    "#infra/*": "./packages/infra/src/*"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "@google/generative-ai": "^0.24.1",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.70.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "openai": "^6.25.0",
    "qrcode": "^1.5.4",
    "redis": "^4.7.1",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.1",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "concurrently": "^9.2.1",
    "jest": "^30.0.0",
    "mongodb-memory-server": "^10.2.0",
    "supertest": "^7.1.0"
  },
"scripts": {
  "start": "node apps/api/src/app/server.js",

  "dev": "concurrently \"npm:dev:server\" \"npm:dev:email\" \"npm:dev:report\" \"npm:dev:export\" \"npm:dev:ai\" \"npm:dev:ws\"",

  "dev:server": "node --watch apps/api/src/app/server.js",

  "dev:email": "node apps/workers/email.worker.js",
  "dev:report": "node apps/workers/report.worker.js",
  "dev:export": "node apps/workers/export.worker.js",
  "dev:ai": "node apps/workers/ai.worker.js",
  "dev:ws": "node apps/ws/server.js"
}
}
